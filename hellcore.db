"...This code should only be run as a server task...";
if (callers())
return E_PERM;
endif
host = `connection_name(player) ! E_INVARG => 0';
if (!host)
"They disconnected.";
return 0;
endif
host = $string_utils:connection_hostname(host);
cens_args = args;
if (length(cens_args) >= 3)
cens_args[$] = "******";
endif
if (player in $login.intercepted_players)
cens_args = {"******"};
endif
if (typeof(h = $network:incoming_connection(player)) == OBJ)
"connected to an object";
return h;
elseif (h)
return 0;
endif
if ($login:redlisted(host))
boot_player(player);
server_log(tostr("REDLISTED: ", player, " from ", host));
return 0;
endif
if (!$login:maybe_limit_commands())
args = $login:parse_command(@args);
return $login:(args[1])(@listdelete(args, 1));
endif
.
