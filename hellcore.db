realwordlen = (rwl = index($ansi:strip(word), " ")) ? rwl - 1 | length($ansi:strip(word));
endwhile
if (!currlen)
broken_lines[idx] = word;
currlen = wordlen;
elseif ((currlen + wordlen) < linelen)
broken_lines[idx] = broken_lines[idx] + word;
currlen = currlen + wordlen;
elseif ((currlen + realwordlen) < linelen)
broken_lines[idx] = broken_lines[idx] + word[1..realwordlen];
idx = idx + 1;
broken_lines = {@broken_lines, indspace};
currlen = indent;
else
