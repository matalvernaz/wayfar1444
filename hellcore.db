#20:96
":_splitwords(STR s) => LIST words -- split and include trailing space.";
{s} = args;
if (!s)
return {};
endif
s = " " + s;
words = {};
lasti = length(s);
while (s)
i = rindex(s[1..lasti - 1], " ");
if ((i == 1) || ((lasti - i) > 1))
words = {s[i + 1..$], @words};
s = s[1..i];
endif
if (i == 1)
break;
endif
lasti = i;
yield 0;
endwhile
return words;
.
