":look_self([OBJ or LIST objs-to-exclude]) => Prints a description of the room and its contents to the player";
{?exclude = {}, @other_args} = args;
this:validate_occupants();
"--- a. options ---";
if (`player.brief ! E_PROPNF => 0')
show_map = 0;
show_desc = 0;
else
show_map = ((this.show_map && (!(this in $rpg.nomap_rooms))) && (!`player.client ! ANY => 0')) && player:check_pref("showmap");
show_desc = player:check_pref("showdesc");
endif
"--- b. info about the player ---";
dark = this:darkness(1, player);
seedark = player:can_see_in_dark();
edark = seedark ? 0 | dark;
terserun = 0;
if ((player.executing && player.queue) && player:check_pref("terserun"))
terserun = (player.executing[1] == $actions.move) && (player.queue[1][1] == $actions.move);
endif
"--- 1. Get the object lists ---";
exclude = (typeof(exclude) == LIST) ? exclude | {exclude};
everything = this:_look_self_obvious(exclude);
exits = this:exits();
creatures = furniture = rendered = {};
for x in (everything)
if (is_a(x, $creature))
creatures = {@creatures, x};
elseif (is_a(x, $furniture))
furniture = {@furniture, x};
endif
endfor
"--- 2. gather actual object descs ---";
if (terserun)
furniture_desc = exit_desc = other_desc = "";
{creature_desc, rendered} = this:_look_self_creatures(furniture, creatures, rendered);
show_desc = 0;
else
{furniture_desc, rendered} = this:_look_self_furniture(furniture, rendered);
{exit_desc, rendered} = this:_look_self_exits(exits, rendered);
{creature_desc, rendered} = this:_look_self_creatures(furniture, creatures, rendered);
{other_desc, rendered} = this:_look_self_others(everything, rendered);
endif
contents = $set_utils:difference(everything, {@rendered, @exits});
if (show_desc)
full_desc = this:description();
else
full_desc = {};
exit_desc = "";
if (has_callable_verb(this, "brief_description"))
full_desc = {@full_desc, @this:brief_description()};
endif
endif
if ((edark < 3) && (edark > -3))
if (furniture_desc)
full_desc = {@full_desc, furniture_desc};
endif
if (exit_desc)
full_desc = {@full_desc, exit_desc};
endif
if (other_desc)
full_desc = {@full_desc, other_desc};
endif
endif
"--- 3. tell descs to player ---";
player:tell("");
if ((!show_map) || (terserun && player:check_pref("nomaprun")))
title_desc = this:title() + (player.brief ? (" (" + (this.public ? "public" | "private")) + ")" | "");
player:tell_lines({title_desc, @full_desc});
else
this:tell_map(full_desc, player);
endif
if (`player.client ! ANY => 0')
this:client_map();
endif
if ((!terserun) && (dark > 1))
this:tell_nearby_lights();
endif
if (((dark < 2) || seedark) && (dark > -2))
if (terserun)
this:tell_contents_terserun(contents);
else
this:tell_contents(contents);
endif
endif
if (((dark < 3) || seedark) && (dark > -3))
if (creature_desc)
player:tell(creature_desc);
endif
endif
if (terserun)
player:tell("");
return;
