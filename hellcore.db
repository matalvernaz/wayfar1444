"Copied from generic room (#3):look_self by Gilmore (#98) Mon Jan  4 18:55:15 2010 CST";
":look_self([OBJ or LIST objs-to-exclude]) => Prints a description of the room and its contents to the player";
"An additional complication is that furniture can provide an integration message which lists its occupants and what they're doing.  This message needs to be grouped with players.";
{?exclude = {}, @other_args} = args;
this:validate_occupants();
show_map = ((this.show_map && (!(this in $rpg.nomap_rooms))) && (!`player.client ! ANY => 0')) && player:check_pref("showmap");
show_desc = player:check_pref("showdesc");
if (`player.brief ! E_PROPNF => 0')
show_map = 0;
show_desc = 0;
endif
player:tell("");
room_desc = "";
exit_desc = "";
furniture_desc = "";
other_desc = "";
player_desc = "";
if (typeof(exclude) == OBJ)
rendered = {exclude, player};
elseif (typeof(exclude) == LIST)
rendered = {@exclude, player};
else
rendered = {player};
endif
everything = this:contents();
furniture = this:occupants($furniture);
creatures = this:occupants($creature);
for x in (everything)
if (`x:is_hidden() ! E_VERBNF')
rendered = setadd(rendered, x);
everything = setremove(everything, x);
endif
endfor
"handle furniture";
for x in (furniture)
if (x in rendered)
continue;
endif
if (msg = x:look_place_msg())
furniture_desc = (furniture_desc + "  ") + msg;
rendered = listappend(rendered, x);
endif
endfor
"handle exits";
if (longexits = player:check_pref("longexits"))
rendered = {@rendered, @this:exits()};
else
for x in (this:exits())
if (x in rendered)
continue;
endif
if (msg = `x:look_place_msg(this) ! E_VERBNF => ""')
exit_desc = (exit_desc + "  ") + msg;
rendered = listappend(rendered, x);
endif
endfor
endif
if (extra = `this:extra_exit_desc(rendered) ! E_VERBNF => ""')
exit_desc = (extra + "  ") + exit_desc;
endif
"handle players";
for x in (furniture)
if (x in rendered)
continue;
endif
if (msg = x:users_msg({player}))
rendered = {@rendered, @x:integrated_objects()};
player_desc = (player_desc + "  ") + msg;
endif
endfor
"now render anyone that's left";
creatures_left = {};
for x in (creatures)
if (x in rendered)
continue;
endif
if (msg = `x:look_place_msg(this) ! E_VERBNF => ""')
player_desc = (player_desc + "  ") + msg;
rendered = setadd(rendered, x);
else
creatures_left = listappend(creatures_left, x);
endif
endfor
"now render players with no :look_place_msg()";
player_desc = (player_desc + "  ") + this:player_integration_msg(creatures_left);
rendered = {@rendered, @creatures_left};
"finally integrate anything that's left";
for x in (everything)
if (is_a(x, $exit))
continue;
elseif (x in rendered)
continue;
elseif (!(msg = `x:look_place_msg(this) ! E_VERBNF => ""'))
continue;
endif
other_desc = (other_desc + "  ") + msg;
rendered = listappend(rendered, x);
endfor
room_desc = $su:trim(room_desc);
exit_desc = $su:trim(exit_desc);
furniture_desc = $su:trim(furniture_desc);
player_desc = $su:trim(player_desc);
other_desc = $su:trim(other_desc);
if (show_desc)
full_desc = this:description();
if (room_desc)
if (typeof(full_desc) == STR)
if (full_desc)
full_desc = {tostr(full_desc, "  ", room_desc, $ansi.reset)};
else
full_desc = {tostr(room_desc, $ansi.reset)};
endif
else
full_desc = {@full_desc, room_desc + $ansi.reset};
endif
endif
else
full_desc = {};
exit_desc = {};
if (has_callable_verb(this, "brief_description"))
full_desc = {@full_desc, @this:brief_description()};
endif
endif
dark = this:darkness();
if (dark < 3)
if (furniture_desc)
full_desc = {@full_desc, furniture_desc};
endif
if (exit_desc)
full_desc = {@full_desc, exit_desc + $ansi.reset};
endif
if (other_desc)
full_desc = {@full_desc, other_desc + $ansi.reset};
endif
endif
if (show_map)
this:tell_map(full_desc);
else
title_desc = this:title();
if (this.public)
title_desc = title_desc + " (public)";
else
title_desc = title_desc + " (private)";
endif
player:tell_lines({title_desc, @full_desc});
endif
if (`player.client ! ANY => 0')
this:client_map();
endif
what = $set_utils:difference(everything, rendered);
for x in (what)
if (is_a(x, $exit))
what = setremove(what, x);
endif
endfor
if (dark > 1)
this:tell_nearby_lights();
endif
if ((dark < 2) || player:can_see_in_dark())
this:tell_contents(what);
endif
if ((dark < 3) || player:can_see_in_dark())
if (player_desc)
player:tell(player_desc);
endif
endif
this:list_exits();
if (this.has_commands == E_NONE)
this:examine_verbs(player);
endif
if (this.has_commands && player:check_pref("showroomcmd"))
player:tell($ansi.cyan, $ansi.bold_on, "[ ", $ansi.bold_off, "There are special commands here.  '", $ansi.bold_on, "ex here", $ansi.bold_off, "' to learn more. ", $ansi.bold_on, "]", $ansi.reset);
endif
if (is_a(area(this), $blueprint))
this:tell_notes();
