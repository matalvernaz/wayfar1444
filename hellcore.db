fm = listappend(fm, itm);
endif
if ((length(ff) == 0) && index(n, "fiber"))
ff = listappend(ff, itm);
endif
endfor
if (length(fm) == 0)
p:tell("Need 1x inert metal.");
return;
endif
if (length(ff) == 0)
p:tell("Need 1x native fiber.");
return;
endif
recycle(fm[1]);
recycle(ff[1]);
r = create($equipment);
r.name = "colonial machete";
r.description = "Crude blade forged from alien ore.";
