#6:330
"Scan for resources.";
p = player;
if ((!valid(p.w_special)) || (p.w_special.eq_type != "harvest"))
p:tell("You need a harvesting tool wielded.");
return;
endif
nodes = {};
for OBJ in (p.location.contents)
try
if (OBJ.is_node)
nodes = listappend(nodes, OBJ);
endif
except e (ANY)
endtry
endfor
tool = p.w_special;
tc = "";
try
tc = tool.h_tool_class;
except e (ANY)
endtry
p:tell(("=== SURVEY: " + tool.name) + " ===");
if (tc != "")
p:tell("  Tool class: " + tc);
endif
if (nodes == {})
p:tell("  No resources detected.");
else
for nd in (nodes)
nc = this:_node_class(nd);
compat = ((tc == "") || (tc == nc)) ? "" | " [WRONG TOOL]";
p:tell((((((((("  [" + nd.name) + "] ") + tostr(nd.count)) + "/") + tostr(nd.max_count)) + " (") + nc) + ")") + compat);
endfor
endif
target = "";
try
target = tool.h_resource;
except e (ANY)
endtry
if (target != "")
p:tell("  Configured: " + target);
else
p:tell("  Target: any");
endif
.
#6:331
"Configure harvesting tool to target a resource type. Usage: configure <ore|fiber|water|salvage|any>.";
p = player;
if ((!valid(p.w_special)) || (p.w_special.eq_type != "harvest"))
p:tell("You need a harvesting tool wielded first. (WIELD <tool>)");
return;
endif
tstr = ((typeof(dobjstr) == STR) && (dobjstr != "")) ? dobjstr | "";
if ((tstr == "") && (args != {}))
for w in (args)
if (typeof(w) == STR)
tstr = (tstr == "") ? w | ((tstr + " ") + w);
endif
endfor
endif
if ((((tstr == "") || (tstr == "any")) || (tstr == "all")) || (tstr == "reset"))
p.w_special.h_resource = "";
p:tell("Harvesting tool reset to collect any available resource.");
return;
endif
valid_types = {"ore", "fiber", "water", "salvage"};
if (!(tstr in valid_types))
p:tell("Valid targets: ore, fiber, water, salvage, any");
return;
endif
p.w_special.h_resource = tstr;
p:tell("Harvesting tool configured to target: " + tstr);
.
#6:332
"Harvest resources using wielded tool.";
p = player;
if ((!valid(p.w_special)) || (p.w_special.eq_type != "harvest"))
p:tell("You need a harvesting tool wielded.");
return;
endif
loc = p.location;
tool = p.w_special;
target_type = "";
try
target_type = tool.h_resource;
except e (ANY)
endtry
tool_class = "";
try
tool_class = tool.h_tool_class;
except e (ANY)
endtry
node = 0;
for OBJ in (loc.contents)
try
if (OBJ.is_node)
if ((target_type == "") || index(OBJ.name, target_type))
nc = this:_node_class(OBJ);
if (((tool_class == "") || (nc == "")) || (tool_class == nc))
node = OBJ;
break;
endif
endif
endif
except e (ANY)
endtry
endfor
if (node == 0)
p:tell("No harvestable resources for this tool here.");
return;
endif
if (node.count <= 0)
p:tell(("The " + node.name) + " is depleted.");
return;
endif
amt = 2;
if (node.count < amt)
amt = node.count;
endif
nc = this:_node_class(node);
harvested = {};
for i in [1..amt]
item = create($thing);
roll = random(100);
if (nc == "mineral")
if (roll <= 60)
item.name = "inert metal";
elseif (roll <= 85)
item.name = "solid-phase metal";
elseif (roll <= 95)
item.name = "responsive metal";
else
item.name = "sand";
endif
elseif (nc == "organic")
if (roll <= 50)
item.name = "native fiber";
elseif (roll <= 75)
item.name = "native lumber";
elseif (roll <= 90)
item.name = "native fungus";
else
item.name = "native berries";
endif
elseif (nc == "energy")
if (roll <= 60)
item.name = "solar kretherson";
elseif (roll <= 85)
item.name = "thermal kretherson";
else
item.name = "intrinsic field kretherson";
endif
elseif (nc == "water")
item.name = "unpurified water";
else
try
item.name = node.yield_name;
except e (ANY)
item.name = "raw resource";
endtry
endif
item.description = "Harvested resource.";
try
item.q_quality = 10 + random(40);
except e (ANY)
endtry
move(item, p);
harvested = listappend(harvested, item.name);
endfor
node.count = node.count - amt;
"Show what was harvested";
for h in (harvested)
p:tell("  + " + h);
endfor
p:tell(((("[" + tostr(node.count)) + "/") + tostr(node.max_count)) + " remaining]");
try
this:award_sp(1);
except e (ANY)
endtry
.
#6:333
"Create the 3 starting rooms for the alpha complex.";
set_task_perms(#2);
"--- Shuttle ---";
shuttle = create($room);
shuttle.name = "Shuttle Interior";
shuttle.description = "A cramped colonial transport shuttle. The hatch is open. Through the viewport you can see the docking clamps of a massive orbital station. Type EXIT to disembark.";
"--- Commerce Main Junction ---";
junction = create($room);
junction.name = "Commerce Main Junction  Alpha Complex";
junction.description = "A wide corridor bustling with automated cargo drones. The air smells of recycled atmosphere and industrial lubricant. The Complex-Alpha Mall Lobby is to the east. The shuttle bay is to the west.";
"--- Complex-Alpha Mall Lobby ---";
lobby = create($room);
lobby.name = "Complex-Alpha Mall Lobby";
lobby.description = "A circular atrium lined with shuttered storefronts. Most are dark. A background selection terminal and a colony dispatch terminal glow on the far wall. The Commerce Main Junction is to the west.";
"Wire exits";
shuttle.east = junction;
junction.west = shuttle;
junction.east = lobby;
lobby.west = junction;
player:tell("SHUTTLE=#" + tostr(shuttle));
player:tell("JUNCTION=#" + tostr(junction));
player:tell("LOBBY=#" + tostr(lobby));
