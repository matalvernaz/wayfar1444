args = $su:explode(argstr, "/");
if (length(args) != 3)
player:tell("Usage: @megasub one thing/another thing/#12345");
return;
endif
target = toobj(args[3]);
if (tostr(target) != args[3])
player:tell("'", args[3], "' is not an object.");
return;
endif
if (!valid(target))
player:tell(target, " is invalid.");
return;
endif
if ((target.owner != player) && (!player.wizard))
player:tell("No write permission on ", target, " (must be owner or a wizard.)");
return;
endif
find = args[1];
repl = args[2];
to_change = {};
for p in ($ou:all_properties(target))
yield;
original = target.(p);
if (typeof(original) == HASH)
player:tell("@megasub: skipping .", p, " - it's a hash");
continue;
endif
{didsub, result} = this:_megasubsub(find, repl, original);
if (didsub)
player:tell("@megasub: .", p);
player:tell("  old: ", toliteral(original));
player:tell("  new: ", toliteral(result));
to_change = {@to_change, {p, result}};
endif
endfor
if (!$cu:yes_or_no("@megasub: Commit changes?"))
player:tell("Aborted.");
return;
endif
for change in (to_change)
{p, newvalue} = change;
target.(p) = newvalue;
yield;
endfor
player:tell("Complete.");
