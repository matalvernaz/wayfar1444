{e, ?further = {}, ?net = this.bugnet} = args;
{errcode, msg, value, traceback} = e;
try
if (errsub = $lu:assoc(errcode, this.err_subs))
msg = errsub[2][random($)];
endif
except e (ANY)
$archwiz:tell("errsub: ", e[1]);
endtry
