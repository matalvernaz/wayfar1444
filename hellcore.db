#103:34
":describe_coord_dir(OBJ sourceroom, OBJ destroom)";
"Return something like 'southwest'.";
"This is as-the-crow-flies, not pathed.";
if (typeof(args[1]) == OBJ)
source = args[1];
sourcex = source.x;
sourcey = source.y;
else
sourcex = args[1][1];
sourcey = args[1][2];
endif
if (typeof(args[2]) == OBJ)
dest = args[2];
destx = dest.x;
desty = dest.y;
else
destx = args[2][1];
desty = args[2][2];
endif
dx = tofloat(destx - sourcex);
dy = tofloat(desty - sourcey);
adx = abs(dx);
ady = abs(dy);
if (ady > 0.0)
dx_to_dy = adx / ady;
else
dx_to_dy = 100.0;
endif
if (dx_to_dy > 2.0)
if (dx > 0.0)
dir = "east";
else
dir = "west";
endif
elseif (dx_to_dy < 0.5)
if (dy > 0.0)
dir = "south";
else
dir = "north";
endif
elseif ((dx > 0.0) && (dy > 0.0))
dir = "southeast";
elseif ((dx > 0.0) && (dy < 0.0))
dir = "northeast";
elseif ((dx < 0.0) && (dy > 0.0))
dir = "southwest";
else
dir = "northwest";
endif
return dir;
.
