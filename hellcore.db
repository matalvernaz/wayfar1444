actor:tell(target:dnamec(), " isn't here.");
return;
endif
endif
"get messages";
if (valid(target))
"transitive";
msgs["self"] = social.tsocial_self_msg;
msgs["others"] = social.tsocial_others_msg;
msgs["target"] = social.tsocial_target_msg;
else
"intransitive";
msg = social.social_msg;
msgs["others"] = msg;
self_msg = strsub(msg, "%DN", "You");
self_msg = strsub(self_msg, "%N", "You");
self_msg = strsub(self_msg, "%p", "your");
