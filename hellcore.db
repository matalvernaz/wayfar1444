#27:21
":levenshtein(from, to) => Calculate the Levelshtein distance between 'from' and 'to', each of which must either be a list or a string.  Note:  may call suspend().";
{from, to} = args;
m = length(from);
n = length(to);
d = $lu:make(m + 1, $lu:make(n + 1));
for i in [1..m + 1]
d[i][1] = i - 1;
endfor
for j in [1..n + 1]
d[1][j] = j - 1;
endfor
for i in [1..m]
for j in [1..n]
if (from[i] == to[j])
cost = 0;
else
cost = 1;
endif
d[i + 1][j + 1] = min(d[i][j + 1] + 1, d[i + 1][j] + 1, d[i][j] + cost);
endfor
$cu:sin();
endfor
return d[m + 1][n + 1];
.
#27:22
":random(seq) => INT randomly selected from seq.";
seq = args[1];
if (!seq)
raise(E_INVARG);
endif
if (length(seq) % 2)
seq = {@seq, $minint};
endif
intervals = {};
for i in [1..length(seq) / 2]
yield;
ivl = {seq[(2 * i) - 1], seq[2 * i]};
len = ivl[2] - ivl[1];
intervals = {@intervals, {len, ivl}};
endfor
chosen_ivl = $ru:weighted_random(@intervals);
chosen_len = chosen_ivl[2] - chosen_ivl[1];
result = chosen_ivl[1] + (random(chosen_len) - 1);
return result;
.
