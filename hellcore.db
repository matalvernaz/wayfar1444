old_names = {"Mineral Flats", "Scrublands", "Broken Ground", "Dust Plains", "Thermal Zone"};
new_names = {"Mountain", "Forest", "Desert", "Jungle", "Volcanic"};
fixed = 0;
total = 0;
for prop in (properties(#458))
if (index(prop, "rp"))
try
r = #458.(prop);
if (valid(r))
total = total + 1;
idx = r.name in old_names;
if (idx > 0)
r.name = new_names[idx];
fixed = fixed + 1;
endif
endif
except e (ANY)
endtry
if ((total % 50) == 0)
suspend(0);
endif
endif
endfor
player:tell((("MARKER_FIXED=" + tostr(fixed)) + "/") + tostr(total));
.
