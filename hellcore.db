":do_setup(WHAT obj)";
"Run GM interactive setup on an object, based on its .setup_list.";
what = args[1];
player:tell($ansi.cyan + $ansi.bold_on, "[ Setting up ", $su:nn(what), ". Hit enter to keep old values. ]", $ansi.reset);
for x in (what.setup_list)
x = $su:explode(x, ",");
prop = x[1];
desc = x[2];
default = what.(prop);
type = {"integer", "object", "string", "", "list", "", "", "", "", "", "float"}[typeof(default) + 1];
val = $cu:read(tostr("Enter ", desc, " (now: ", default, ") (type: ", type, ")"));
if (val == "")
val = default;
endif
if (typeof(default) == INT)
val = toint(val);
elseif (typeof(default) == FLOAT)
val = tofloat(val);
elseif (typeof(default) == OBJ)
val = toobj(val);
if (val == #0)
val = #-1;
endif
endif
what.(prop) = (val == "") ? default | val;
player:tell(" ", $ansi.cyan, tostr(what), ".", prop, " = ", toliteral(what.(prop)), $ansi.reset);
endfor
player:tell($ansi.cyan + $ansi.bold_on, "[ Setup complete. ]", $ansi.reset);
