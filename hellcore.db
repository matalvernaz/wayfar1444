if ((instring[$ - 1..$] == "ex") || (instring[$ - 1..$] == "ix"))
nounval = instring[1..$ - 2] + "ices";
elseif (instring[$ - 1..$] == "um")
nounval = instring[1..$ - 2] + "a";
elseif (instring[$ - 1..$] == "us")
nounval = instring[1..$ - 2] + "i";
elseif (instring[$ - 1..$] == "os")
nounval = instring[1..$ - 2] + "oi";
elseif (instring[$ - 1..$] == "oy")
nounval = instring[1..$ - 2] + "oys";
elseif (instring[$ - 1..$] == "ey")
nounval = instring[1..$ - 2] + "eys";
elseif (instring[$ - 1..$] == "ay")
nounval = instring[1..$ - 2] + "ays";
elseif (instring[$] == "y")
nounval = instring[1..$ - 1] + "ies";
elseif (((instring[$ - 1..$] == "ch") && (instring[$ - 2] != "o")) || (instring[$..1] == "sh"))
nounval = instring + "es";
elseif ((instring[$] == "x") || (instring[$] == "s"))
