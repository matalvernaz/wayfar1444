this:list_exits();
"--- 4. tell about commands in the room ---";
if (this.has_commands == E_NONE)
this:examine_verbs(player);
endif
if (this.has_commands && player:check_pref("showroomcmd"))
player:tell($ansi.cyan, $ansi.bold_on, "[ ", $ansi.bold_off, "There are special commands here.  '", $ansi.bold_on, "ex here", $ansi.bold_off, "' to learn more. ", $ansi.bold_on, "]", $ansi.reset);
endif
if ((hint = `this.hint_msg ! ANY') && player:check_pref("hints"))
fork (1)
(player.location == this:room()) && player:systell(hint);
