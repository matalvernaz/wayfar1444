if ((min_val <= 101) && (max_val >= 101))
if (random(100) <= this.special_event_drop_chance)
special_drop = 1;
endif
endif
endif
if (special_drop)
o = this.special_event_treasure[random($)];
if (o.f && children(o))
branches = {o, @$ou:fertile_branches(o)};
else
p = {o};
endif
elseif (parent == $treasure)
branches = $rpg.treasure_cache;
else
branches = {parent, @$ou:fertile_branches(parent)};
endif
if (!p)
for x in (branches)
yield;
if ((length(x.name) > 8) && (x.name[1..8] == "generic "))
continue;
elseif (special_drop)
p = setadd(p, x);
elseif (`x.no_random_spawn ! ANY' && (x != parent))
continue;
else
val = x.value;
if ((val < min_val) || (val > max_val))
continue;
endif
p = setadd(p, x);
endif
endfor
endif
if (p)
p = p[random($)];
child = $rpg:spawn(p);
if ((typeof(child) == OBJ) && valid(child))
return child;
else
$nets.heartnet:sys_announce("-- $rpg:spawn returned a fucked value in random_treasure: " + tostr(child));
return #-1;
endif
else
return #-1;
endif
