top = traceback[1];
line = tostr($su:nn(top[4]), ":", top[2], @(top[1] != top[4]) ? {" (this == ", $su:nn(top[1]), ")"} | {}, ", line ", top[6], ": ", msg);
net:announce(#-1, line, 1);
if (value)
line = "  thrown error value: " + toliteral(value);
if (length(line) > 60)
line = line[1..57] + "...";
endif
net:announce(#-1, line, 1);
endif
brokencode = `verb_code(top[4], top[2])[top[6]] ! ANY => ""';
vloc = top[4];
for redirect in (this.error_nets)
{rnet, rtrees} = redirect;
for parent in (rtrees)
if (is_a(vloc, parent))
net = rnet;
break;
endif
endfor
yield;
endfor
if (brokencode)
net:announce(#-1, tostr("  ", brokencode), 1);
endif
for fr in (traceback[2..$])
line = tostr("... called from ", $su:nn(fr[4]), ":", fr[2], @(fr[1] != fr[4]) ? {" (this == ", $su:nn(fr[1]), ")"} | {}, ", line ", fr[6]);
net:announce(#-1, line, 1);
endfor
if (further)
if (typeof(further) == LIST)
for l in (args[2])
net:announce(#-1, l, 1);
endfor
else
net:announce(#-1, args[2], 1);
endif
endif
`net:cleanup() ! ANY => 0';
