"Spawn or retrieve a wilderness room at (planet, x, y).";
"Usage: $ods:spawn_room(planet_obj, x_int, y_int) -> room";
{planet, x, y} = args;
set_task_perms(this.owner);
"Build property key: strip # from planet ref so name is a valid identifier";
pkey = strsub(tostr(planet), "#", "p");
"Encode negative coords: replace - with m (minus)";
xkey = strsub(tostr(x), "-", "m");
ykey = strsub(tostr(y), "-", "m");
prop = (((("r" + pkey) + "_x") + xkey) + "_y") + ykey;
"Check if room already exists";
if (prop in properties(this))
r = this.(prop);
if (valid(r))
return r;
endif
endif
"Create new wilderness room";
r = create($wroom);
r.x = x;
r.y = y;
r.planet = planet;
"5 major biomes from perlin (0-4), then rare dangerous overlay (5-6)";
b = perlin_2d(x, y, 1.0, 1.5, 5, 1);
if (b < 0)
b = 0;
elseif (b > 4)
b = 4;
endif
"~5% chance of dangerous biome overlay (fungal=5, volcanic=6)";
danger_roll = perlin_2d((x * 3) + 97, (y * 3) + 53, 3.0, 2.5, 7, 1);
if (danger_roll == 9)
b = 5;
elseif (danger_roll == 0)
b = 6;
endif
r.biome = b;
bnames = planet.biome_names;
r.name = bnames[b + 1];
"Store the room";
add_property(this, prop, r, {player, "rc"});
"Possibly spawn a resource node";
this:populate(r, planet);
return r;
.
#458:1
"Spawn resource node based on biome.";
{room, planet} = args;
set_task_perms(this.owner);
x = room.x;
y = room.y;
b = room.biome;
roll = perlin_2d((x * 7) + 13, (y * 5) + 7, 2.0, 2.0, 10, 1);
if (roll < 7)
return;
endif
"  0=Mountain  -> mineral (ore)";
"  1=Forest    -> organic (fiber)";
"  2=Desert    -> mineral (salvage/sand)";
"  3=Jungle    -> water + organic";
"  4=Underwater -> water";
"  5=Fungal    -> organic (rare)";
"  6=Volcanic  -> energy (kretherson)";
proto = 0;
if (b == 0)
proto = $ore_node;
elseif (b == 1)
proto = $fiber_node;
elseif (b == 2)
if (roll > 8)
proto = $salvage_pile;
else
proto = $ore_node;
endif
elseif (b == 3)
if (roll > 8)
proto = $fiber_node;
else
proto = $water_node;
endif
elseif (b == 4)
proto = $water_node;
elseif (b == 5)
proto = $fiber_node;
elseif (b == 6)
proto = $energy_node;
endif
if (!valid(proto))
return;
endif
node = create(proto);
node.count = proto.max_count;
move(node, room);
.
